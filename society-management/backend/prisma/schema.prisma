generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String
  role     Role

  societyId  Int? //optional 
  society    Society?    @relation(fields: [societyId], references: [id])
  complaints Complaint[]

  createdAt DateTime @default(now())
}

model Society {
  id      Int    @id @default(autoincrement())
  name    String
  address String
  city    String

  users      User[]
  complaints Complaint[]
  createdAt  DateTime    @default(now())
  flats      Flat[]
}

enum Role {
  SUPER_ADMIN
  ADMIN
  RESIDENT
  TENANT
  SECURITY
  ACCOUNTANT
}

model Complaint {
  id          Int    @id @default(autoincrement())
  title       String
  description String
  status      String @default("OPEN")

  userId    Int
  societyId Int

  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  society Society @relation(fields: [societyId], references: [id])
}

model Flat {
  id        Int    @id @default(autoincrement())
  block     String
  flatNo    String
  societyId Int

  society Society @relation(fields: [societyId], references: [id])
}

model Visitor {
  id      Int    @id @default(autoincrement())
  name    String
  phone   String
  vehicle String
   residentId Int
  checkIn    DateTime  @default(now())
  checkOut   DateTime?
}

model Notice {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  societyId Int
  createdAt DateTime @default(now())
}

model Maintenance {
  id     Int    @id @default(autoincrement())
  amount Float
  month  String
  userId Int
  status String
}

model Booking {
 id      Int @id @default(autoincrement())
 amenity String
 date    DateTime
 slot    String
 userId  Int
 status  String @default("PENDING")
}