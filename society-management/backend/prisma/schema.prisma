generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Society {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())

  users     User[]
}

model User {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  password   String
  role       String
  societyId  Int
  createdAt  DateTime @default(now())

  society    Society  @relation(fields: [societyId], references: [id])
}
